{
  "name": "ticket-system-backend",
  "version": "1.0.0",
  "description": "Support ticket / feedback tracking API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node migrations/run.ts",
    "seed": "ts-node seed/run.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --forceExit --detectOpenHandles --testPathPattern='__tests__/unit'",
    "test:integration": "jest --forceExit --detectOpenHandles --testPathPattern='__tests__/integration'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "mysql2": "^3.11.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
